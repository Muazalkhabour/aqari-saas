// Proposal only. Do NOT merge these models into schema.prisma until the
// production infrastructure is ready for a real DB-backed security pipeline.
//
// الهدف من هذا الملف:
// - نقل auth audit log من JSON file إلى Prisma لاحقاً.
// - نقل rate limit counters من file storage إلى قاعدة البيانات إذا لم يُستخدم Redis.
// - إبقاء طبقة lib/rate-limit-store.ts قابلة للاستبدال بدون تغيير منطق الدخول.

enum AuthAuditOutcome {
  SUCCESS
  BLOCKED
  FAILURE
}

model AuthAuditLog {
  id                String           @id @default(uuid())
  scope             String
  outcome           AuthAuditOutcome
  identifierHash    String
  identifierLabel   String
  clientIp          String
  reason            String
  retryAfterSeconds Int?
  createdAt         DateTime         @default(now())

  @@index([scope, createdAt])
  @@index([identifierHash, createdAt])
  @@index([outcome, createdAt])
}

model AuthRateLimitBucket {
  id           String   @id @default(uuid())
  bucketKey    String   @unique
  scope        String
  identifierHash String
  clientIp     String
  attempts     Json
  blockedUntil DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([scope, updatedAt])
  @@index([identifierHash, updatedAt])
}

// Recommended production order later:
// 1. Decide between Redis and DB as the primary rate-limit backend.
// 2. If Redis is available, keep Prisma only for AuthAuditLog and use Redis for buckets.
// 3. If Redis is unavailable, activate both models and replace the file adapter in lib/rate-limit-store.ts.
// 4. Keep JSON fallback only for local development.